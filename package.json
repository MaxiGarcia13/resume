{
  "name": "resume",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Maximiliano Garcia Mortigliengo resume",
  "author": "Maximiliano Garcia Mortigliengo",
  "homepage": "https://github.com/MaxiGarcia13/resume#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/resume.git"
  },
  "keywords": [
    "resume",
    "cv",
    "portfolio"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "preview": "vite preview",
    "postinstall": "npx simple-git-hooks",
    "phoenix": "rm -rf dist && rm -rf node_modules && npm install"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@maxigarcia/eslint-config": "^1.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "lint-staged": "^16.3.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
