---
import { cn } from '@maxigarcia/js-utils';
import ActionButton from '../shared/actions/button.astro';
import SparklesIcon from '../shared/icons/sparkles.astro';

const { class: className } = Astro.props;
---

<ActionButton class={cn(className, 'hidden sm:block')} id="ai-button">
  <SparklesIcon slot="icon" />
</ActionButton>

<script>
  const aiButton = document.getElementById('ai-button');
  const aiAside = document.getElementById('ai-aside');

  aiButton.addEventListener('click', () => {
    aiAside.classList.toggle('hidden');
  });
</script>
