---
import Button from './shared/actions/button.astro';
import MoonIcon from './shared/icons/moon.astro';
import SunIcon from './shared/icons/sun.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<Button
  type="button"
  id="switch-theme"
  class={className}
  data-switch-theme
  aria-label="Toggle color theme"
>
  <Fragment slot="icon">
    <MoonIcon class="hidden dark:block" />
    <SunIcon class="block dark:hidden" />
  </Fragment>
</Button>

<script>
  import {
    initializeThemeStore,
    toggleTheme,
  } from '@/stores/theme/theme.store';

  initializeThemeStore();

  const switchThemeButton = document.getElementById('switch-theme');

  function syncThemeToggleLabel() {
    const theme = document.documentElement.dataset.theme;
    switchThemeButton?.setAttribute(
      'aria-label',
      theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme',
    );
  }

  syncThemeToggleLabel();

  switchThemeButton?.addEventListener('click', () => {
    toggleTheme();
    syncThemeToggleLabel();
  });
</script>
