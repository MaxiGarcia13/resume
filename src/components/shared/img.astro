---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '@maxigarcia/js-utils';
import ContentLoader from './content-loader.astro';

interface Props extends HTMLAttributes<'img'> {
  class?: string;
}

const { src, alt, class: className, loading = 'lazy', ...rest } = Astro.props;
const imgId = `img-${src}`;
---

<figure class={cn('relative overflow-hidden shrink-0', className)}>
  <ContentLoader id={imgId}>
    <img
      id={imgId}
      src={src}
      alt={alt}
      loading={loading}
      class="object-contain w-full h-full shrink-0"
      {...rest}
    />
  </ContentLoader>
</figure>
