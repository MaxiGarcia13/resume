---
import { cn } from '@maxigarcia/js-utils';
import { Image } from 'astro:assets';
import Link from '@/components/shared/actions/link/link.astro';
import ImgLoader from '@/components/shared/img-loader.astro';

interface Props {
  /** Public website URL (preview API source and link target). */
  src: string;
  /** Project title; used for accessible preview alt text. */
  title: string;
  class?: string;
}

const { src, title, class: className } = Astro.props;

const previewSrc = `https://snap-website-api.vercel.app/website-to-blob-img?url=${src}`;
const previewId = `preview-${src}`;
---

<Link
  href={src}
  target="_blank"
  noWrap
  class={cn('block relative', className)}
  aria-label={`${title} website (opens in new tab)`}
>
  <ImgLoader id={previewId}>
    <Image
      id={previewId}
      src={previewSrc}
      alt={`Preview of ${title}`}
      width={900}
      height={506}
      widths={[100, 200, 300, 400, 500, 600, 700, 800, 900]}
      loading="lazy"
      decoding="async"
      class={cn('w-full h-auto overflow-hidden rounded', className)}
    />
  </ImgLoader>
</Link>
